---
import "../styles/global.css";
import site from "../data/site.json";

interface Props {
  title?: string;
  description?: string;
  article?: boolean;
}

const { title, description, article = false } = Astro.props;
const pageTitle = title ? `${title} — ${site.title}` : `${site.title} — ${site.tagline}`;
const pageDesc = description || site.description;
const canonical = new URL(Astro.url.pathname, Astro.site).toString();
const year = new Date().getFullYear();
---

<!doctype html>
<html lang="ru">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{pageTitle}</title>
    <meta name="description" content={pageDesc} />
    <link rel="canonical" href={canonical} />
    <meta property="og:type" content={article ? "article" : "website"} />
    <meta property="og:title" content={pageTitle} />
    <meta property="og:description" content={pageDesc} />
    <meta property="og:url" content={canonical} />
    <meta property="og:locale" content="ru_RU" />
    <meta name="twitter:card" content="summary_large_image" />
    <link rel="alternate" type="application/rss+xml" title={site.title} href={new URL("/rss.xml", Astro.site)} />
    <link rel="icon" href="data:image/svg+xml,%3Csvg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 32 32'%3E%3Crect width='32' height='32' fill='%23e7e3d9'/%3E%3Cline x1='16' y1='3' x2='16' y2='29' stroke='%231e545c' stroke-width='1.4'/%3E%3Ccircle cx='16' cy='16' r='5.5' fill='none' stroke='%238c6e36' stroke-width='1.4'/%3E%3C/svg%3E" />
  </head>
  <body>
    <header class="mast">
      <div class="wrap mast-in">
        <a class="brand" href="/">
          <span class="coord">40.4°N · 49.9°E — Баку</span>
          <span class="title">{site.title}</span>
          {site.tagline && <span class="tagline">{site.tagline}</span>}
        </a>
        <nav class="nav">
          <a href="/">Лента</a>
          <a href="/rss.xml">RSS</a>
        </nav>
      </div>
    </header>

    <main>
      <slot />
    </main>

    <footer class="foot">
      <div class="wrap foot-in">
        <span>{site.title} · {year}</span>
        <span>40.4°N · 49.9°E</span>
      </div>
    </footer>
  </body>
</html>
