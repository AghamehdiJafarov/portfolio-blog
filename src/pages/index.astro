---
import Base from "../layouts/Base.astro";
import PostCard from "../components/PostCard.astro";
import { getPosts, formatDate, readingMinutes } from "../utils/posts";
import { slugify, accentClass } from "../utils/slug";

const posts = await getPosts();
const categories = [...new Set(posts.map((p) => p.data.category))].sort((a, b) => a.localeCompare(b, "ru"));
const lead = posts[0];
const rest = posts.slice(1);
---

<Base>
  {posts.length === 0 ? (
    <div class="wrap"><div class="empty">
      <h2>Эфир пуст</h2>
      <p>Откройте редактор на /admin и опубликуйте первую депешу.</p>
    </div></div>
  ) : (
    <>
      <section class="hero">
        <div class="hero-glow"></div>
        <div class="wrap">
          <div class="hero-grid">
            <div class={"hero-text " + accentClass(lead.data.category)}>
              <div class="hero-eyebrow">
                <span class="live">Свежая депеша</span>
                <span class="pill">{lead.data.category}</span>
                <span>{formatDate(lead.data.date)}</span>
              </div>
              <h1 class="hero-title"><a href={`/posts/${lead.slug}`}>{lead.data.title}</a></h1>
              {lead.data.dek && <p class="hero-dek">{lead.data.dek}</p>}
              <a class="hero-cta btn" href={`/posts/${lead.slug}`}>Читать депешу <span class="arr">→</span></a>
              <div class="hero-meta">№ {String(posts.length).padStart(2, "0")} · {readingMinutes(lead.entry.body)} мин чтения</div>
            </div>

            <div class="radar" aria-hidden="true">
              <svg viewBox="0 0 400 400" xmlns="http://www.w3.org/2000/svg">
                <defs>
                  <linearGradient id="sweepGrad" x1="0" y1="0" x2="0" y2="1">
                    <stop offset="0%" stop-color="#19e0d8" stop-opacity="0.38" />
                    <stop offset="100%" stop-color="#19e0d8" stop-opacity="0" />
                  </linearGradient>
                </defs>
                <circle class="radar-ring" cx="200" cy="200" r="60" />
                <circle class="radar-ring" cx="200" cy="200" r="110" />
                <circle class="radar-ring" cx="200" cy="200" r="160" />
                <circle class="radar-ring" cx="200" cy="200" r="190" />
                <line class="radar-cross" x1="200" y1="10" x2="200" y2="390" />
                <line class="radar-cross" x1="10" y1="200" x2="390" y2="200" />
                <g class="radar-sweep">
                  <path d="M200,200 L200,20 A180,180 0 0 1 327,73 Z" fill="url(#sweepGrad)" />
                  <line x1="200" y1="200" x2="200" y2="20" stroke="#19e0d8" stroke-width="1.6" />
                </g>
                <circle cx="132" cy="128" r="3.4" fill="#19e0d8" />
                <circle class="ping" cx="132" cy="128" r="4" fill="#19e0d8" style="animation-delay:0s" />
                <circle cx="288" cy="150" r="3.4" fill="#ff9e2c" />
                <circle class="ping" cx="288" cy="150" r="4" fill="#ff9e2c" style="animation-delay:0.9s" />
                <circle cx="300" cy="270" r="3.4" fill="#8a6dff" />
                <circle class="ping" cx="300" cy="270" r="4" fill="#8a6dff" style="animation-delay:1.7s" />
                <circle cx="116" cy="272" r="3.4" fill="#ff5d73" />
                <circle class="ping" cx="116" cy="272" r="4" fill="#ff5d73" style="animation-delay:2.5s" />
                <circle class="radar-halo" cx="200" cy="200" r="14" />
                <circle class="radar-core" cx="200" cy="200" r="5" />
                <text class="radar-label" x="210" y="214">БАКУ</text>
              </svg>
            </div>
          </div>
        </div>
      </section>

      <div class="wrap">
        <div class="filters">
          <span class="chip on">Все</span>
          {categories.map((c) => (
            <a class="chip" href={`/categories/${slugify(c)}`}>{c}</a>
          ))}
        </div>
        <div class="feed">
          {rest.map((p, i) => (
            <PostCard
              slug={p.slug}
              title={p.data.title}
              dek={p.data.dek}
              category={p.data.category}
              date={p.data.date}
              cover={p.data.cover}
              body={p.entry.body}
              index={rest.length - i}
            />
          ))}
        </div>
      </div>
    </>
  )}
</Base>
