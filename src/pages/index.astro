---
import Base from "../layouts/Base.astro";
import PostCard from "../components/PostCard.astro";
import { getPosts, formatDate, readingMinutes } from "../utils/posts";
import { slugify, accentClass } from "../utils/slug";

const posts = await getPosts();
const categories = [...new Set(posts.map((p) => p.data.category))].sort((a, b) => a.localeCompare(b, "ru"));
const lead = posts[0];
const rest = posts.slice(1);
---

<Base>
  {posts.length === 0 ? (
    <div class="wrap"><div class="empty">
      <h2>Эфир пуст</h2>
      <p>Откройте редактор на /admin и опубликуйте первую депешу.</p>
    </div></div>
  ) : (
    <>
      <section class={"hero " + accentClass(lead.data.category)}>
        <div class="wrap">
          <div class="hero-grid">
            <div class="hero-text">
              <div class="hero-eyebrow">
                <span>✦ Свежая депеша</span>
                <span>{lead.data.category}</span>
                <span>{formatDate(lead.data.date)}</span>
              </div>
              <h1 class="hero-title"><a href={`/posts/${lead.slug}`}>{lead.data.title}</a></h1>
              {lead.data.dek && <p class="hero-dek">{lead.data.dek}</p>}
              <a class="hero-cta btn" href={`/posts/${lead.slug}`}>Читать депешу <span class="arr">→</span></a>
              <div class="hero-meta">№ {String(posts.length).padStart(2, "0")} · {readingMinutes(lead.entry.body)} мин чтения</div>
            </div>

            <div class="compass" aria-hidden="true">
              <svg viewBox="0 0 400 400" xmlns="http://www.w3.org/2000/svg">
                <circle class="compass-ring" cx="200" cy="200" r="186" />
                <g class="compass-ticks">
                  <circle cx="200" cy="200" r="176" fill="none" stroke="#8a7656" stroke-width="6" stroke-dasharray="2 13.5" opacity="0.7" />
                </g>
                <circle class="compass-ring" cx="200" cy="200" r="150" stroke-width="1" />
                <rect x="128" y="128" width="144" height="144" transform="rotate(45 200 200)" fill="none" stroke="#dfa42b" stroke-width="1" opacity="0.55" />
                <g transform="rotate(45 200 200)">
                  <path class="compass-rose-c" d="M200 96 L207 200 L200 304 L193 200 Z" opacity="0.9" />
                  <path class="compass-rose-c" d="M96 200 L200 193 L304 200 L200 207 Z" opacity="0.9" />
                </g>
                <path class="compass-rose-a" d="M200 62 L211 200 L200 338 L189 200 Z" />
                <path class="compass-rose-b" d="M62 200 L200 189 L338 200 L200 211 Z" />
                <text class="compass-letter" x="200" y="44" text-anchor="middle">N</text>
                <text class="compass-letter" x="366" y="208" text-anchor="middle">E</text>
                <text class="compass-letter" x="200" y="374" text-anchor="middle">S</text>
                <text class="compass-letter" x="34" y="208" text-anchor="middle">W</text>
                <circle class="compass-hub" cx="200" cy="200" r="10" />
              </svg>
            </div>
          </div>
        </div>
      </section>

      <div class="wrap">
        <div class="filters">
          <span class="chip on">Все</span>
          {categories.map((c) => (
            <a class="chip" href={`/categories/${slugify(c)}`}>{c}</a>
          ))}
        </div>
        <div class="feed">
          {rest.map((p, i) => (
            <PostCard
              slug={p.slug}
              title={p.data.title}
              dek={p.data.dek}
              category={p.data.category}
              date={p.data.date}
              cover={p.data.cover}
              body={p.entry.body}
              index={rest.length - i}
            />
          ))}
        </div>
      </div>
    </>
  )}
</Base>
